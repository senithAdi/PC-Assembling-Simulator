# ============================================================
# PC Assembly Simulator — Server Environment Variables
# Copy this file to `.env` and fill in your own values.
# ============================================================

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/pc_simulator
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pc_simulator
MONGODB_URI=mongodb://127.0.0.1:27017/pc_simulator

# JWT secret — change this to a long random string in production.
JWT_SECRET=change_me_to_a_long_random_string

# API server port
PORT=3001

# Allowed frontend origin (Vite dev server by default)
CLIENT_ORIGIN=http://localhost:5173
